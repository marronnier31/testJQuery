<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.happyjob.study.domain.homework.dao.HomeworkFileDAO">

    <select id="selectFile"
            parameterType="int"
            resultType="kr.happyjob.study.domain.homework.model.HomeworkFileVO">

        SELECT
            file_id,
            name,
            logical_path,
            physical_path,
            size
        FROM file
        WHERE file_id = #{fileId}

    </select>

</mapper>
