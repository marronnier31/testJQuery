<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.happyjob.study.domain.student.dao.SFileDAO">


    <!-- 파일 조회 -->
    <select id="selectFile"
            parameterType="long"
            resultType="kr.happyjob.study.domain.student.model.FileVO">
        SELECT
        file_id,
        size,
        type,
        name,
        logical_path,
        physical_path
        FROM file
        WHERE file_id = #{file_id}
    </select>

</mapper>
